    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "pdfkit": "^0.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
