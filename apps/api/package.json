    "@nestjs/platform-express": "^11.1.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ligas/config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/node": "^26.1.0",
